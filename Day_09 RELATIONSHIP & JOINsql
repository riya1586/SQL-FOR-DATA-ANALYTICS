--ONE TO ONE RELATIONSHIP---
--MARKS TABLE--
CREATE TABLE MARKS (
MARKS_ID SERIAL PRIMARY KEY,
STUDENT_ID INT,
SUBJECT VARCHAR(50),
MARKS INT,
FOREIGN KEY (STUDENT_ID) REFERENCES STUDENT(STUDENT_ID)
);


