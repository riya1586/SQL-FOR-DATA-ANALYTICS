-- View Data
SELECT * FROM Students;

-- WHERE
SELECT * FROM Students
WHERE city='Noida';

-- ORDER BY
SELECT * FROM Students
ORDER BY marks DESC;

-- GROUP BY
SELECT course, COUNT(*) AS total_students
FROM Students
GROUP BY course;

-- Aggregate Functions
SELECT
MAX(marks) AS highest_marks,
MIN(marks) AS lowest_marks,
AVG(marks) AS average_marks,
SUM(marks) AS total_marks
FROM Students;

-- LIMIT
SELECT * FROM Students
ORDER BY marks DESC
LIMIT 3;

-- UPDATE
UPDATE Students
SET marks=90
WHERE student_id=1;

-- DELETE
DELETE FROM Students
WHERE student_id=8;

-- Final View
SELECT * FROM Students;
